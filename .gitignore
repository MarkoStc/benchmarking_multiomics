logs/
*/logs/
*.out
*.err
*.log

# Daemon state
*.state

# Model / data blobs
*.joblib
*.pkl
*.pkl.gz
*.pt
*.pth
*.npy
*.npz
*.h5
*.hdf5

# Python
__pycache__/
*.pyc
.ipynb_checkpoints/

